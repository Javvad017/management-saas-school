{
  "name": "school-management-system",
  "version": "1.0.0",
  "description": "School Management Desktop Application",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"nodemon backend/server.js\" \"vite\" \"wait-on http://127.0.0.1:5173 && wait-on http://127.0.0.1:5000 && cross-env NODE_ENV=development electron .\"",
    "dev:backend": "nodemon backend/server.js",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .",
    "reset-admin": "node backend/reset-admin.js",
    "build": "vite build && electron-builder",
    "build:analyze": "cross-env ANALYZE=true vite build",
    "preview": "vite preview",
    "clean": "rimraf dist dist-electron node_modules/.vite"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.14",
    "postcss": "^8.4.49",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "terser": "^5.46.0",
    "vite": "^5.4.11",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.school.management",
    "productName": "School Management System",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "dist-electron"
    }
  }
}
